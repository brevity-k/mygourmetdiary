{
  "name": "mygourmetdiary",
  "private": true,
  "workspaces": [
    "mobile",
    "web",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.8",
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "file-type": "21.3.4",
    "teeny-request": "10.1.2",
    "retry-request": "8.0.2",
    "http-proxy-agent": "7.0.2",
    "tmp": "0.2.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-worklets": "0.8.1",
    "eslint": {
      "ajv": "6.14.0"
    },
    "schema-utils@3.3.0": {
      "ajv": "6.14.0"
    },
    "ajv-keywords@3.5.2": {
      "ajv": "6.14.0"
    }
  },
  "dependencies": {
    "expo": "~54.0.33",
    "next": "16.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-worklets": "0.8.1"
  },
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "npm run build --workspace=web",
    "lint": "npm run lint --workspace=web",
    "typecheck": "npx --workspace=web tsc --noEmit && npx --workspace=mobile tsc --noEmit",
    "test": "echo 'No test runner configured yet'"
  }
}
