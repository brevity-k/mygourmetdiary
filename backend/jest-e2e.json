{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!uuid/|meilisearch/)"
  ],
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@prisma/client$": "<rootDir>/prisma/generated/client/client",
    "^meilisearch$": "<rootDir>/../node_modules/meilisearch/dist/index.js"
  }
}
